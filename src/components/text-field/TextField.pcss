:root {
  --error-color: #F44336;
}

.textField {
  display: inline-block;
  position: relative;
  text-align: left;
  
  &:focus-within {
    .placeholder {
      font-size: 0.75em;
      top: unset;
      bottom: 2.25em;
    }
  }
}

.inputContainer {
  position: relative;
}

.input {
  background: none;
  color: inherit;
  outline: none;
  border: none;
  padding-bottom: 0.25em;
  border-bottom: solid 1px;
  width: 100%;
  
  &.disabled {
    opacity: 0.45;
  }
  &.error {
    border-bottom: solid 1px var(--error-color);
  }
}

.placeholder {
  display: block;
  position: absolute;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  pointer-events: none;
  width: 100%;
  top: 0;
  
  &.disabled {
    opacity: 0.45;
  }
  &.open {
    font-size: 0.75em;
    top: unset;
    bottom: 2.25em;
  }
}

.endAdornment {
  position: absolute;
  top: 0;
  right: 0;
}

.error:not(.input) {
  color: var(--error-color);
  font-size: 0.75em;
  margin-top: 0.4em;
}
