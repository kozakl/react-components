:root {
  --border-color: #FFFFFF;
  --error-color: #FF0000;
}

.field {
  background: none;
  outline: none;
  padding: 0.35rem 0;
  border: none;
  border-bottom: solid 1px var(--border-color);
  transition: border-bottom 0.2s;
  
  &.error {
    border-bottom: solid 1px var(--error-color);
  }
  &::placeholder {
    color: var(--border-color);
    opacity: 1;
  }
}

.error:not(.field) {
  color: var(--error-color);
  margin: 0.5rem 0;
}
