.richTextArea {
  position: relative;
  z-index: 0;
}

.container {
  min-height: inherit;
}

.border {
  border-bottom: solid 1px;
  
  &.error {
    border-bottom: solid 1px var(--text-color-error);
  }
}

.error {
  color: var(--text-color-error);
  font-size: 0.75em;
  margin-top: 0.4em;
}
