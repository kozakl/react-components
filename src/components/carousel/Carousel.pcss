.list {
  overflow-x: scroll;
  scroll-behavior: smooth;
  scroll-snap-type: x mandatory;
  white-space: nowrap;
  
  & > * {
    scroll-snap-align: center;
    display: inline-block;
  }
}

.indicatorDot {
  display: inline-block;
  background: red;
  border-radius: 50%;
  margin: 0 1em;
  width: 0.5rem;
  height: 0.5rem;
}
